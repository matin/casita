# Copy to .env for live/private runs. The demo path does not need credentials:
# uv run casita demo

# Optional for live route matrices. This is a paid Google Maps Routes API SKU.
# The demo reads cached rows from fixtures/demo.sqlite and never calls the API.
# Without a key, live route calculations fall back to haversine estimates.
GOOGLE_MAPS_API_KEY=

# Optional for Vertex-backed LLM commands such as enrich/analyze-prefs.
CASITA_GCP_PROJECT=
CASITA_VERTEX_LOCATION=global
CASITA_EXTRACT_MODEL=gemini-3.1-pro-preview
CASITA_RANK_MODEL=gemini-3.1-pro-preview

# Local SQLite overrides.
CASITA_DB_PATH=
CASITA_ROUTE_CACHE_DB=
CASITA_ROUTES_OFFLINE=0

# Optional private cloud/publish plumbing.
CASITA_GCS_BUCKET=
CASITA_GCS_DB_OBJECT=casita/db.sqlite
CASITA_GCS_PUBLISH_PENDING_OBJECT=casita/publish_pending.json
CASITA_FIREBASE_PROJECT=
CASITA_SITE_URL=http://localhost:8765
